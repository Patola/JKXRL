#!/bin/sh
# JKXR launcher - Star Wars Jedi Knight: Jedi Academy (single player, VR)
#
# Game data is NOT included: you need your own copy of Jedi Academy
# (Steam/GOG). This launcher looks for its GameData directory in the default
# Steam library; for any other location set JKXR_JKA_GAMEDATA, e.g.:
#   JKXR_JKA_GAMEDATA="/games/SteamLibrary/steamapps/common/Jedi Academy/GameData" jkxr-jka
set -e

LIBDIR=/usr/lib/jkxr
SHAREDIR=/usr/share/jkxr/jka
HOMEDATA="${XDG_DATA_HOME:-$HOME/.local/share}/openjk/base"

GAMEDATA="${JKXR_JKA_GAMEDATA:-}"
if [ -z "$GAMEDATA" ]; then
	for d in \
		"$HOME/.local/share/Steam/steamapps/common/Jedi Academy/GameData" \
		"$HOME/.steam/steam/steamapps/common/Jedi Academy/GameData"; do
		if [ -f "$d/base/assets0.pk3" ]; then GAMEDATA=$d; break; fi
	done
fi
if [ -z "$GAMEDATA" ] || [ ! -d "$GAMEDATA/base" ]; then
	echo "jkxr-jka: Jedi Academy GameData directory not found." >&2
	echo "Set JKXR_JKA_GAMEDATA to it, e.g.:" >&2
	echo "  JKXR_JKA_GAMEDATA=\"/games/SteamLibrary/steamapps/common/Jedi Academy/GameData\" jkxr-jka" >&2
	exit 1
fi

# Sync the VR asset pk3s into the engine's per-user home path, which is the
# highest-priority search path - no need to write into the game directory.
mkdir -p "$HOMEDATA"
for pk3 in "$SHAREDIR"/*.pk3; do
	cp -u "$pk3" "$HOMEDATA/"
done

# The OpenXR session uses the X11/GLX graphics binding (XWayland is fine).
export SDL_VIDEODRIVER=x11
exec "$LIBDIR/openjk_sp.x86_64" +set fs_basepath "$GAMEDATA" "$@"
